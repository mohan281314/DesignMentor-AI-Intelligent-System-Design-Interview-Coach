# =============================================================================
# DesignMentor AI v2.1 — Environment Variables
# =============================================================================
# USAGE:
#   Development : cp .env.example .env  → fill in values
#   Railway     : set these in the Railway dashboard (Variables tab)
#   Docker Prod : cp .env.example .env.production → fill in values
#
# NEVER commit .env or .env.production to Git!
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="DesignMentor AI"
APP_VERSION="2.1.0"

# "development" | "staging" | "production" | "test"
# IMPORTANT: set to "production" on Railway — enables Alembic migrations,
# disables /docs, enforces secret_key length, uses JSON logging
ENVIRONMENT=development

# Set to false in production
DEBUG=false


# =============================================================================
# SERVER
# =============================================================================
HOST=0.0.0.0

# Railway auto-injects $PORT — leave as 8000 locally
PORT=8000

# Number of Gunicorn workers  (Railway: start with 2, scale up)
WEB_CONCURRENCY=2


# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Dev (SQLite — zero setup)
DATABASE_URL=sqlite:///./designmentor.db

# Production — Railway auto-injects this when you add the PostgreSQL plugin:
# DATABASE_URL=postgresql+psycopg2://postgres:<password>@<host>:5432/railway

# Enable SQL query logging (dev only — very noisy)
DB_ECHO=false


# =============================================================================
# REDIS
# =============================================================================
# Dev (local Redis)
REDIS_URL=redis://localhost:6379/0

# Production — Railway auto-injects this when you add the Redis plugin:
# REDIS_URL=redis://default:<password>@<host>:6379

REDIS_CACHE_TTL=3600


# =============================================================================
# SECURITY  ← MUST CHANGE FOR PRODUCTION
# =============================================================================
# Generate a secure key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_32_RANDOM_CHARS_MINIMUM

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# =============================================================================
# OAUTH2 (Optional — leave blank to disable)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Replace with your production domain:
OAUTH_REDIRECT_URL=https://your-backend.up.railway.app/api/v1/auth/callback


# =============================================================================
# AI / LLM  ← REQUIRED
# =============================================================================

# Groq — Primary LLM provider (free tier: https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model options:
#   llama-3.3-70b-versatile  — best quality  (100k tokens/day free)
#   llama-3.1-8b-instant     — fastest       (500k tokens/day free)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — Optional fallback (leave blank to disable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# "groq" | "openai"
LLM_PROVIDER=groq
LLM_FALLBACK_ENABLED=true

OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096


# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true

# Requests per minute per IP (increase for authenticated users if needed)
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10


# =============================================================================
# CORS  ← MUST SET FOR PRODUCTION
# =============================================================================
# Development:
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Production — replace with your actual domain(s):
# CORS_ORIGINS=["https://designmentor.ai","https://www.designmentor.ai","https://your-frontend.up.railway.app"]


# =============================================================================
# FILE STORAGE
# =============================================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# PDF temp directory (Railway uses ephemeral filesystem — consider S3 for prod)
PDF_EXPORT_ENABLED=true
PDF_TEMP_DIR=temp/pdfs


# =============================================================================
# ANALYTICS
# =============================================================================
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90


# =============================================================================
# LOGGING
# =============================================================================
# "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=INFO

# "json" for production (structured logs), "text" for development
LOG_FORMAT=json


# =============================================================================
# SESSION
# =============================================================================
SESSION_TTL_SECONDS=1800


# =============================================================================
# FRONTEND (Next.js) — set these in the Railway Frontend service
# =============================================================================
# Replace with your deployed backend Railway URL:
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
