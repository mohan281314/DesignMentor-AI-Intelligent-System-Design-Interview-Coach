# DesignMentor AI - Environment Configuration v2.0
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="DesignMentor AI"
APP_VERSION="2.0.0"
ENVIRONMENT=development  # development, staging, production, test
DEBUG=true

# =============================================================================
# SERVER
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+psycopg2://designmentor:designmentor@localhost:5432/designmentor
DB_ECHO=false  # Set to true to log SQL queries

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600  # seconds

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# IMPORTANT: Generate a secure secret key (min 32 characters)
# You can use: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OAUTH2 PROVIDERS (Optional)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth  
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/auth/callback

# =============================================================================
# AI/LLM CONFIGURATION
# =============================================================================
# Groq (Primary - Free Tier Available)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (Fallback - Requires Paid Account)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# LLM Settings
LLM_PROVIDER=groq  # groq or openai
LLM_FALLBACK_ENABLED=true
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# FILE STORAGE
# =============================================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# =============================================================================
# PDF EXPORT
# =============================================================================
PDF_EXPORT_ENABLED=true
PDF_TEMP_DIR=temp/pdfs

# =============================================================================
# ANALYTICS
# =============================================================================
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# =============================================================================
# BACKGROUND JOBS (Celery - Optional)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
SESSION_TTL_SECONDS=1800  # 30 minutes
