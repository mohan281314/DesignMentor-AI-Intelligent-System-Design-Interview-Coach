# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for these file types
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Keep Windows line endings for batch files
*.bat   text eol=crlf
